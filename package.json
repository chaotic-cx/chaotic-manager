{
    "name": "chaotic-manager",
    "version": "1.0.0",
    "main": "dist/index.js",
    "author": "Garuda Team",
    "license": "AGPL-3.0-or-later",
    "private": true,
    "dependencies": {
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/addon-webgl": "^0.19.0",
        "@xterm/xterm": "^6.0.0",
        "async-mutex": "^0.5.0",
        "await-timeout": "^1.1.1",
        "await-to-js": "^3.0.0",
        "command-line-args": "^6.0.2",
        "cors": "^2.8.6",
        "css-loader": "^7.1.4",
        "dependency-graph": "^1.0.0",
        "dockerode": "^4.0.10",
        "express": "5.2.1",
        "ioredis": "^5.10.1",
        "moleculer": "^0.15.0",
        "node-telegram-bot-api": "^0.67.0",
        "ssh2": "^1.17.0",
        "style-loader": "^4.0.0",
        "typescript": "^6.0.2"
    },
    "scripts": {
        "build": "tsc -P tsconfig.app.json && rspack",
        "build-docs": "typedoc --out docs 'src/*.ts' 'src/*/*.ts' --plugin typedoc-material-theme --themeColor '#1e1e2e'",
        "format:check": "prettier --check .",
        "format:write": "prettier --write .",
        "lint:check": "eslint .",
        "lint:write": "eslint --fix .",
        "start": "node dist/index.js",
        "start:dev": "tsc-watch -P tsconfig.app.json --onSuccess 'node --env-file=.env dist/index.js database --web-port 8080'",
        "start:dev-builder": "tsc-watch -P tsconfig.app.json --onSuccess 'sudo node --env-file=.env dist/index.js builder'",
        "test": "jest",
        "test-schedule": "node dist/index.js schedule --target-repo=chaotic-aur --source-repo=chaotic-aur '--arch-mirror=https://arch.mirror.constant.com/$repo/os/$arch' chaotic-mirrorlist"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@rspack/cli": "^1.7.11",
        "@rspack/core": "^1.7.11",
        "@types/await-timeout": "^0.3.4",
        "@types/command-line-args": "^5.2.3",
        "@types/config": "^4.4.0",
        "@types/cors": "^2.8.19",
        "@types/dockerode": "^4.0.1",
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.0",
        "@types/node-telegram-bot-api": "^0.64.14",
        "@types/ssh2": "^1.15.5",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-tsdoc": "^0.5.2",
        "html-webpack-plugin": "^5.6.6",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsc-watch": "^7.2.0",
        "typed-moleculer": "^4.1.2",
        "typedoc": "^0.28.18",
        "typedoc-material-theme": "^1.4.1",
        "typescript-eslint": "^8.58.0"
    },
    "packageManager": "yarn@4.13.0"
}
